<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Seat Selection</title>
    <style>
        body {
            font-family: Arial, sans-serif;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }
        .seat-details {
            background-color: #f9f9f9;
            padding: 15px;
            border-radius: 5px;
            margin-bottom: 20px;
        }
        .seat-details h2 {
            margin-top: 0;
            color: #333;
        }
        .seat-details p {
            margin: 5px 0;
        }
        .seat-selection-form {
            margin-top: 20px;
            text-align: center;
        }
        .seat-selection-form input[type="submit"] {
            background-color: #4CAF50;
            color: #fff;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.3s;
        }
        .seat-selection-form input[type="submit"]:hover {
            background-color: #45a049;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Seat Selection</h1>

        <div class="seat-details">
            <h2>Flight Information</h2>
            <p><strong>Flight ID:</strong> <%= seatInfo.flightID %></p>
            <!-- Display other flight details -->
        </div>

        <!-- Add seat selection form here -->
        <div class="seat-selection-form">
            <form action="/payment" method="post">
                <h2>Select Number of Seats</h2>
                <p><label for="numSeats">Number of Seats:</label></p>
                <p><input type="number" id="numSeats" name="numSeats" min="1" required></p>
                <input type="hidden" name="flightID" value="<%= seatInfo.flightID %>">
                <input type="submit" value="Proceed to Payment">
            </form>
        </div>

        <a href="/search">Back to Search</a>
    </div>
</body>
</html>

